---
const title = 'Connexion Keycloak';
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #07111f;
        --panel: rgba(15, 23, 42, 0.9);
        --panel-border: rgba(148, 163, 184, 0.18);
        --text: #e2e8f0;
        --muted: #94a3b8;
        --accent: #38bdf8;
        --accent-strong: #0ea5e9;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
        margin: 0;
      }

      body {
        font-family: system-ui, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(56, 189, 248, 0.2), transparent 30%),
          radial-gradient(circle at right bottom, rgba(14, 165, 233, 0.16), transparent 28%),
          var(--bg);
        color: var(--text);
        display: grid;
        place-items: center;
        padding: 24px;
      }

      .panel {
        width: min(100%, 720px);
        border: 1px solid var(--panel-border);
        border-radius: 28px;
        background: var(--panel);
        box-shadow: 0 24px 80px rgba(2, 6, 23, 0.45);
        padding: 32px;
        backdrop-filter: blur(18px);
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 0.75rem;
        color: var(--accent);
        margin: 0 0 12px;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1;
      }

      p {
        margin: 16px 0 0;
        color: var(--muted);
        line-height: 1.6;
        max-width: 60ch;
      }

      .status {
        margin-top: 24px;
        padding: 16px 18px;
        border-radius: 18px;
        background: rgba(15, 23, 42, 0.72);
        border: 1px solid rgba(148, 163, 184, 0.14);
        color: var(--text);
      }

      .hint {
        margin-top: 12px;
        font-size: 0.95rem;
        color: var(--muted);
      }

      .actions {
        margin-top: 28px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid transparent;
        font-weight: 700;
        text-decoration: none;
      }

      .button.primary {
        color: #04111d;
        background: linear-gradient(135deg, #7dd3fc, var(--accent-strong));
      }

      .button.secondary {
        color: var(--text);
        border-color: var(--panel-border);
        background: rgba(15, 23, 42, 0.45);
      }

      .footnote {
        margin-top: 18px;
        color: var(--muted);
        font-size: 0.92rem;
      }
    </style>
  </head>
  <body>
    <main class="panel">
      <p class="eyebrow">Keycloak</p>
      <h1>Connexion sécurisée</h1>
      <p>
        Cette page prépare la connexion OAuth2 / PKCE, envoie l’utilisateur vers Keycloak,
        puis récupère le retour sur la page de callback.
      </p>

      <div class="status" id="status">Préparation de la redirection vers Keycloak…</div>
      <div class="hint" id="hint">Si rien ne se passe, vérifie la configuration du client Keycloak.</div>

      <div class="actions">
        <a class="button primary" href="/private/service">Retour au portail</a>
        <a class="button secondary" id="manual-link" href="#">Ouvrir Keycloak manuellement</a>
      </div>

      <p class="footnote">
        Configuration attendue: PUBLIC_KEYCLOAK_ISSUER, PUBLIC_KEYCLOAK_CLIENT_ID et un redirect URI
        autorisé vers /auth/callback.
      </p>
    </main>

    <script type="module">
      import {
        buildAuthorizeUrl,
        createCodeChallenge,
        createCodeVerifier,
        storePendingAuthState,
      } from '../../lib/keycloak';

      const status = document.getElementById('status');
      const hint = document.getElementById('hint');
      const manualLink = document.getElementById('manual-link');

      const url = new URL(window.location.href);
      const returnTo = url.searchParams.get('returnTo') ?? '/private/service';
      const redirectUri = `${window.location.origin}/auth/callback`;

      try {
        const state = crypto.randomUUID();
        const verifier = createCodeVerifier();
        const challenge = await createCodeChallenge(verifier);

        storePendingAuthState({ state, verifier, returnTo });

        const loginUrl = buildAuthorizeUrl({
          redirectUri,
          state,
          codeChallenge: challenge,
        });

        if (manualLink) {
          manualLink.setAttribute('href', loginUrl);
        }

        if (status) {
          status.textContent = 'Redirection vers la page de connexion Keycloak…';
        }

        window.location.replace(loginUrl);
      } catch (error) {
        if (status) {
          status.textContent = 'Impossible de lancer la connexion Keycloak.';
        }

        if (hint) {
          hint.textContent = error instanceof Error ? error.message : 'Erreur inconnue.';
        }

        manualLink?.setAttribute('href', `/auth/login?returnTo=${encodeURIComponent(returnTo)}`);
      }
    </script>
  </body>
</html>