---
const title = 'Portail des services';

const session = Astro.locals.session;
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
const loginHref = `/auth/login?returnTo=${encodeURIComponent(currentPath)}`;
const logoutHref = '/auth/logout';
const sessionLabel = session
  ? `Session active jusqu’au ${new Intl.DateTimeFormat('fr-FR', {
      dateStyle: 'medium',
      timeStyle: 'short',
    }).format(new Date(session.expiresAt))}`
  : 'Aucune session détectée.';

const services = [
  {
    name: 'Nextcloud',
    href: 'https://nextcloud.4a2s.ch',
    description: 'Fichiers, synchronisation et partage.',
    accent: '#22c55e',
  },
  {
    name: 'Jellyfin',
    href: 'https://media.4a2s.ch',
    description: 'Médiathèque personnelle.',
    accent: '#38bdf8',
  },
  {
    name: 'Grafana',
    href: 'https://monitoring.4a2s.ch',
    description: 'Tableaux de bord et supervision.',
    accent: '#f97316',
  },
  {
    name: 'Portainer',
    href: 'https://portainer.4a2s.ch',
    description: 'Gestion des conteneurs et stacks.',
    accent: '#a78bfa',
  },
] as const;
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #050b16;
        --surface: rgba(15, 23, 42, 0.88);
        --surface-border: rgba(148, 163, 184, 0.16);
        --text: #e2e8f0;
        --muted: #94a3b8;
        --accent: #38bdf8;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
        margin: 0;
      }

      body {
        font-family: system-ui, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(56, 189, 248, 0.16), transparent 28%),
          radial-gradient(circle at 100% 100%, rgba(14, 165, 233, 0.12), transparent 30%),
          linear-gradient(180deg, #0f172a 0%, #050b16 100%);
        color: var(--text);
        padding: 24px;
      }

      .shell {
        width: min(1120px, 100%);
        margin: 0 auto;
      }

      .hero {
        display: grid;
        gap: 18px;
        padding: 32px;
        border: 1px solid var(--surface-border);
        background: var(--surface);
        border-radius: 28px;
        box-shadow: 0 24px 80px rgba(2, 6, 23, 0.48);
        backdrop-filter: blur(18px);
      }

      .eyebrow {
        margin: 0;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: 0.75rem;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.2rem, 5vw, 4.8rem);
        line-height: 0.95;
        max-width: 12ch;
      }

      .intro {
        margin: 0;
        max-width: 68ch;
        color: var(--muted);
        line-height: 1.65;
        font-size: 1.02rem;
      }

      .meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .chip,
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        border-radius: 999px;
        padding: 0 16px;
        border: 1px solid var(--surface-border);
        background: rgba(15, 23, 42, 0.5);
        color: var(--text);
        text-decoration: none;
        font-weight: 600;
      }

      .button.primary {
        border-color: transparent;
        background: linear-gradient(135deg, #7dd3fc, #0ea5e9);
        color: #04111d;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 18px;
        margin: 34px 0 16px;
      }

      .section-head h2 {
        margin: 0;
        font-size: 1.25rem;
      }

      .section-head p {
        margin: 0;
        color: var(--muted);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 16px;
      }

      .card {
        grid-column: span 6;
        display: grid;
        gap: 12px;
        padding: 22px;
        border-radius: 24px;
        border: 1px solid var(--surface-border);
        background: rgba(15, 23, 42, 0.72);
        box-shadow: 0 16px 48px rgba(2, 6, 23, 0.28);
      }

      .card-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: start;
      }

      .badge {
        width: 14px;
        height: 14px;
        border-radius: 999px;
        box-shadow: 0 0 20px currentColor;
        color: var(--badge-color, #38bdf8);
        background: currentColor;
        flex: 0 0 auto;
      }

      .card h3 {
        margin: 0;
        font-size: 1.2rem;
      }

      .card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .card a {
        justify-self: start;
        margin-top: 8px;
      }

      .toast {
        margin-top: 18px;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid rgba(56, 189, 248, 0.16);
        background: rgba(8, 15, 29, 0.7);
        color: var(--muted);
      }

      @media (max-width: 720px) {
        body {
          padding: 16px;
        }

        .hero {
          padding: 24px;
        }

        .card {
          grid-column: span 12;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <section class="hero">
        <p class="eyebrow">Portail privé</p>
        <h1>Services déployés, derrière Keycloak.</h1>
        <p class="intro">
          Cette page sert de tableau de bord aux services internes. La session est créée côté
          serveur, stockée dans un cookie HttpOnly, puis validée par le middleware Astro avant
          d’afficher les ressources privées.
        </p>

        <div class="meta">
          <a class="button primary" href={loginHref}>Se connecter via Keycloak</a>
          <a class="chip" href="/">Retour au site</a>
          <a class="chip" href={logoutHref}>Se déconnecter</a>
        </div>

        <div class="toast">{sessionLabel}</div>
      </section>

      <section>
        <div class="section-head">
          <div>
            <h2>Services</h2>
            <p>Remplace les URLs par tes vrais sous-domaines si besoin.</p>
          </div>
        </div>

        <div class="grid">
          {services.map((service) => (
            <article class="card">
              <div class="card-top">
                <div>
                  <h3>{service.name}</h3>
                  <p>{service.description}</p>
                </div>
                <span class="badge" style={`--badge-color: ${service.accent}`}></span>
              </div>
              <a class="button" href={service.href} target="_blank" rel="noreferrer">
                Ouvrir {service.name}
              </a>
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>